<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,user-scalable=no,maximum-scale=1">
<title>Elfin AI Asistan</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#060a14;--sf:#0c1322;--cd:#111b30;--bd:#1a2a4a;--bdL:#243558;
  --pr:#ffc72c;--prG:#ffc72c44;--ac:#00c8ff;--acG:#00c8ff33;
  --gn:#22c55e;--rd:#ef4444;--tx:#e8edf8;--txM:#9aa8c7;--txD:#5e6f94;
}
html,body{height:100%;overflow:hidden}
body{background:var(--bg);color:var(--tx);font-family:'Segoe UI',-apple-system,sans-serif}
#app{display:flex;flex-direction:column;height:100%;position:relative}
#app::before{content:'';position:fixed;inset:0;opacity:.02;pointer-events:none;
  background-image:radial-gradient(var(--ac) 1px,transparent 1px);background-size:30px 30px}

.header{padding:10px 14px;display:flex;justify-content:space-between;align-items:center;
  border-bottom:1px solid var(--bd);background:rgba(12,19,34,.9);backdrop-filter:blur(12px);z-index:20;flex-shrink:0}
.logo{width:32px;height:32px;border-radius:10px;background:linear-gradient(135deg,var(--pr),#e8a800);
  display:flex;align-items:center;justify-content:center;font-weight:900;font-size:14px;color:var(--bg)}
.hdr-l{display:flex;align-items:center;gap:8px}
.hdr-r{display:flex;align-items:center;gap:6px}
.st-badge{display:flex;align-items:center;gap:6px;padding:4px 10px;background:var(--cd);
  border-radius:16px;border:1px solid var(--bd);font-size:11px;color:var(--txM)}
.st-dot{width:6px;height:6px;border-radius:50%}
.btn-s{padding:4px 10px;border-radius:8px;border:1px solid var(--bd);background:transparent;
  color:var(--txD);font-size:11px;cursor:pointer}

.stage{flex:1;display:flex;flex-direction:column;overflow:hidden;position:relative}
.av-area{display:flex;align-items:center;justify-content:center;position:relative;flex-shrink:0;transition:all .5s}
.av-area.idle{padding:16px 0;min-height:280px}
.av-area.active{padding:6px 0 0;min-height:140px}

/* Product Card */
.pc-w{position:absolute;top:0;width:42%;height:100%;display:flex;flex-direction:column;justify-content:center;padding:8px;z-index:5}
.pc-w.left{left:0;animation:slL .5s cubic-bezier(.34,1.56,.64,1)}
.pc-w.right{right:0;animation:slR .5s cubic-bezier(.34,1.56,.64,1)}
.pc{background:rgba(12,19,34,.96);border-radius:16px;padding:12px;backdrop-filter:blur(12px)}
.pc-h{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:6px}
.pc-t{font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.06em}
.pc-x{background:none;border:none;color:var(--txD);font-size:14px;cursor:pointer}
.pc-n{font-size:15px;font-weight:800;color:var(--tx);margin-bottom:2px;line-height:1.2}
.pc-p{font-size:18px;font-weight:800;margin-bottom:6px}
.pc-d{font-size:10.5px;color:var(--txM);line-height:1.4;margin-bottom:8px}
.pc-fs{display:flex;flex-wrap:wrap;gap:3px;margin-bottom:10px}
.pc-f{padding:2px 6px;border-radius:5px;font-size:9px;font-weight:600}
.pc-btn{width:100%;padding:9px;border-radius:10px;border:none;font-size:12px;font-weight:700;cursor:pointer}
.pc-hint{font-size:8px;color:var(--txD);text-align:center;margin-top:5px}

.chat{flex:1;overflow-y:auto;padding:0 12px 6px;display:flex;flex-direction:column}
.chat-sp{flex:1}
.bw{margin-bottom:7px;display:flex;animation:fU .3s ease}
.bw.u{justify-content:flex-end;padding-left:28px}
.bw.a{justify-content:flex-start;padding-right:20px}
.bb{padding:9px 13px;font-size:13.5px;line-height:1.5;max-width:100%;word-break:break-word}
.bb.u{border-radius:14px 14px 4px 14px;background:linear-gradient(135deg,var(--pr),#ffdb6b);color:var(--bg);font-weight:500}
.bb.a{border-radius:14px 14px 14px 4px;background:var(--cd);border:1px solid var(--bd)}
.td{display:flex;gap:5px;padding:8px 14px}
.td span{width:8px;height:8px;border-radius:50%;background:var(--ac);animation:dp 1s ease infinite}
.td span:nth-child(2){animation-delay:.15s}
.td span:nth-child(3){animation-delay:.3s}
.chips{display:flex;flex-wrap:wrap;gap:5px;padding:6px 0;animation:fU .4s}
.chip{padding:7px 12px;border-radius:18px;border:1px solid var(--bdL);background:var(--cd);
  color:var(--txM);font-size:12px;cursor:pointer;transition:all .2s}
.chip:active{border-color:var(--pr);color:var(--pr)}

.inbar{padding:8px 12px 12px;border-top:1px solid var(--bd);background:rgba(12,19,34,.9);
  backdrop-filter:blur(12px);display:flex;gap:8px;align-items:flex-end;z-index:20;flex-shrink:0}
.inbar input{flex:1;padding:10px 12px;border-radius:12px;border:1px solid var(--bd);
  background:var(--cd);color:var(--tx);font-size:13px;outline:none}
.inbar input:focus{border-color:var(--ac)}
.inbar input::placeholder{color:var(--txD)}
.snd{width:40px;height:40px;border-radius:12px;border:none;font-size:17px;font-weight:700;
  cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.ptt-w{display:flex;flex-direction:column;align-items:center;gap:2px}
.ptt{width:48px;height:48px;border-radius:50%;border:none;color:white;font-size:20px;cursor:pointer;
  display:flex;align-items:center;justify-content:center;transition:all .2s}
.ptt-l{font-size:9px;color:var(--txD)}

.idle-s{text-align:center;padding:0 20px}
.idle-t{font-size:22px;font-weight:300;margin-bottom:4px}
.idle-t b{font-weight:800;color:var(--pr)}
.idle-sub{font-size:12px;color:var(--txM);margin-bottom:16px}
.btn-go{padding:12px 28px;border:none;border-radius:14px;background:linear-gradient(135deg,var(--pr),#ffdb6b);
  color:var(--bg);font-size:14px;font-weight:700;cursor:pointer;box-shadow:0 4px 20px var(--prG)}
.btn-go:active{transform:scale(.97)}

/* Settings Panel */
.settings-overlay{position:fixed;inset:0;background:rgba(0,0,0,.7);backdrop-filter:blur(6px);
  display:flex;align-items:center;justify-content:center;z-index:300;padding:16px}
.settings-card{background:var(--sf);border-radius:20px;padding:20px;width:100%;max-width:380px;
  border:1px solid var(--bd)}
.settings-title{font-size:16px;font-weight:700;margin-bottom:14px;display:flex;justify-content:space-between;align-items:center}
.settings-label{font-size:12px;color:var(--txM);margin-bottom:4px;display:block}
.settings-input{width:100%;padding:10px 12px;border-radius:10px;border:1px solid var(--bd);
  background:var(--cd);color:var(--tx);font-size:13px;outline:none;margin-bottom:12px;font-family:monospace}
.settings-input:focus{border-color:var(--ac)}
.settings-btn{width:100%;padding:11px;border-radius:12px;border:none;background:var(--pr);
  color:var(--bg);font-size:14px;font-weight:700;cursor:pointer}
.settings-note{font-size:11px;color:var(--txD);margin-top:10px;line-height:1.5;padding:8px 10px;
  background:var(--cd);border-radius:8px;border:1px solid var(--bd)}
.settings-status{display:flex;align-items:center;gap:6px;font-size:12px;margin-bottom:8px}
.settings-ok{color:var(--gn)}
.settings-no{color:var(--rd)}

/* Toast */
.toast{position:fixed;top:52px;left:50%;transform:translateX(-50%);padding:8px 16px;
  border-radius:12px;background:var(--cd);border:1px solid var(--bd);font-size:12px;
  color:var(--txM);z-index:100;animation:fU .3s;pointer-events:none}

/* Modal */
.mo{position:fixed;inset:0;background:rgba(0,0,0,.75);backdrop-filter:blur(8px);
  display:flex;align-items:center;justify-content:center;z-index:200;padding:16px;animation:fi .3s}
.mc{background:var(--sf);border-radius:20px;padding:22px;width:100%;max-width:400px;max-height:85vh;overflow-y:auto}
.mc-x{background:none;border:none;color:var(--txD);font-size:20px;cursor:pointer}
.mf{display:flex;flex-direction:column;gap:5px;margin-bottom:16px}
.mfi{display:flex;align-items:center;gap:8px;padding:7px 10px;background:var(--cd);border-radius:8px;
  border:1px solid var(--bd);font-size:12px}
.mfi-d{width:6px;height:6px;border-radius:50%}
.mc-btn{width:100%;padding:12px;border-radius:12px;border:none;font-size:14px;font-weight:700;cursor:pointer}

@keyframes dp{0%,100%{opacity:.3;transform:scale(.8)}50%{opacity:1;transform:scale(1.1)}}
@keyframes fU{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
@keyframes fi{from{opacity:0}to{opacity:1}}
@keyframes slR{from{opacity:0;transform:translateX(40px)}to{opacity:1;transform:translateX(0)}}
@keyframes slL{from{opacity:0;transform:translateX(-40px)}to{opacity:1;transform:translateX(0)}}
::-webkit-scrollbar{width:3px}
::-webkit-scrollbar-thumb{background:var(--bd);border-radius:3px}
</style>
</head>
<body>
<div id="app"></div>
<div id="modal-root"></div>
<div id="toast-root"></div>

<script>
// ═══ DATA ═══
const PRODUCTS=[
  {id:"t1",type:"tarife",name:"YAPBOZ 8GB",price:"449 TL/ay",desc:"8GB internet, 1000dk, 1000SMS",features:["8GB Internet","1000 Dakika","1000 SMS","Fizy","TV+"]},
  {id:"t2",type:"tarife",name:"YAPBOZ 20GB",price:"649 TL/ay",desc:"20GB internet, sinirsiz dakika ve SMS",features:["20GB Internet","Sinirsiz Dk","Sinirsiz SMS","Fizy","TV+"]},
  {id:"t3",type:"tarife",name:"YAPBOZ 50GB",price:"949 TL/ay",desc:"50GB internet, sinirsiz her sey",features:["50GB Internet","Sinirsiz Dk","Sinirsiz SMS","Platinum"]},
  {id:"t4",type:"tarife",name:"BenimPaketim 4GB",price:"279 TL/ay",desc:"4GB internet, 500dk",features:["4GB Internet","500 Dakika","500 SMS"]},
  {id:"c1",type:"cihaz",name:"iPhone 15",price:"64.999 TL",desc:"A16 Bionic, 48MP kamera, 128GB",features:["6.1\" OLED","48MP Kamera","A16 Bionic","128GB"]},
  {id:"c2",type:"cihaz",name:"Samsung S24",price:"54.999 TL",desc:"Galaxy AI, 50MP kamera, 256GB",features:["6.2\" AMOLED","50MP Kamera","Galaxy AI","256GB"]},
  {id:"c3",type:"cihaz",name:"Xiaomi 14",price:"29.999 TL",desc:"Leica kamera, Snapdragon 8 Gen 3",features:["6.36\" AMOLED","Leica 50MP","SD 8 Gen3","256GB"]},
  {id:"c4",type:"cihaz",name:"Samsung A55",price:"21.999 TL",desc:"Super AMOLED, 5000mAh",features:["6.6\" AMOLED","50MP Kamera","5000mAh","128GB"]},
  {id:"i1",type:"internet",name:"Fiber 50Mbps",price:"449 TL/ay",desc:"50 Mbps, limitsiz",features:["50 Mbps","Limitsiz","Ucretsiz Modem"]},
  {id:"i2",type:"internet",name:"Fiber 100Mbps",price:"549 TL/ay",desc:"100 Mbps, limitsiz",features:["100 Mbps","Limitsiz","TV+ Hediye"]},
];

const SYS=`Sen "Elfin" adinda Konya Elfin Iletisim magazasinin (Turkcell Yetkili Bayi) AI asistanisin.

URUNLER:
${JSON.stringify(PRODUCTS)}

HER CEVABIN SADECE JSON OLSUN:
{"message":"cevabin buraya","product_id":null}
Urun onerirsen product_id ekle:
{"message":"Sagimda gordugunuz bu tarife tam size gore!","product_id":"t2"}

KURALLAR:
- 2-3 cumle kisa oz
- Sicak samimi Turkce
- Urun onerirken sagimda/solumda gordugunuz de
- Emoji KULLANMA
- SADECE JSON formatinda cevap ver baska hicbir sey yazma`;

// ═══ STATE ═══
const S={
  mode:"idle",msgs:[],input:"",loading:false,pointDir:null,
  product:null,pSide:"right",lastSide:"right",detailProd:null,
  mouth:0,eye:{x:0,y:0},blink:false,holding:false,
  apiKey:localStorage.getItem('elfin_api_key')||'',
  showSettings:false,toast:null
};
let inactT,mouthT,rec;

// ═══ TTS ═══
let voices=[];
function loadV(){voices=speechSynthesis.getVoices()}
if('speechSynthesis' in window){loadV();speechSynthesis.onvoiceschanged=loadV;
  // Unlock audio on first interaction
  const unlockAudio=()=>{const u=new SpeechSynthesisUtterance('');u.volume=0;speechSynthesis.speak(u)};
  document.addEventListener('touchstart',unlockAudio,{once:true});
  document.addEventListener('click',unlockAudio,{once:true});
}

function trVoice(){
  // Prefer higher quality voices
  const all=voices.filter(v=>v.lang.startsWith('tr'));
  const google=all.find(v=>v.name.includes('Google'));
  if(google)return google;
  const online=all.find(v=>!v.localService);
  if(online)return online;
  return all[0]||null;
}

function speak(text){
  return new Promise(res=>{
    if(!('speechSynthesis' in window)||!text){res();return}
    speechSynthesis.cancel();
    const u=new SpeechSynthesisUtterance(text);
    u.lang='tr-TR';u.rate=0.9;u.pitch=1.0;u.volume=1;
    const v=trVoice();if(v)u.voice=v;
    S.mode="speaking";startMouth();render();
    u.onend=()=>{stopMouth();res()};
    u.onerror=()=>{stopMouth();res()};
    setTimeout(()=>speechSynthesis.speak(u),80);
  });
}
function startMouth(){stopMouth();mouthT=setInterval(()=>{S.mouth=(S.mouth+1)%3;rAvatar()},130)}
function stopMouth(){if(mouthT){clearInterval(mouthT);mouthT=null}S.mouth=0}

// ═══ STT ═══
const SR=window.SpeechRecognition||window.webkitSpeechRecognition;

function startSTT(){
  if(!SR||S.holding||S.loading||S.mode==="speaking")return;
  if(location.protocol==='file:'){toast("Mikrofon icin HTTPS gerekli. GitHub Pages'e deploy edin.");return}
  rec=new SR();rec.lang='tr-TR';rec.continuous=false;rec.interimResults=false;
  rec.onresult=e=>{const t=e.results[0]?.[0]?.transcript;if(t)sendMsg(t)};
  rec.onerror=e=>{S.holding=false;render();if(e.error==='not-allowed')toast("Mikrofon izni verilmedi")};
  rec.onend=()=>{S.holding=false;render()};
  try{rec.start();S.holding=true;render()}catch(e){toast("Mikrofon baslatilamadi")}
}
function stopSTT(){try{rec?.stop()}catch(e){}S.holding=false;render()}

// ═══ ANIMATIONS ═══
setInterval(()=>{S.blink=true;rAvatar();setTimeout(()=>{S.blink=false;rAvatar()},120)},2800+Math.random()*2000);
setInterval(()=>{
  if(S.mode==="idle")S.eye={x:(Math.random()-.5)*6,y:(Math.random()-.5)*4};
  else if(S.pointDir==="left")S.eye={x:-4,y:0};
  else if(S.pointDir==="right")S.eye={x:4,y:0};
  else if(S.mode==="listening")S.eye={x:0,y:2};
  else if(S.mode==="thinking")S.eye={x:3,y:-2};
  rAvatar();
},2200);

// ═══ HELPERS ═══
function resetInact(){if(inactT)clearTimeout(inactT);inactT=setTimeout(()=>{speechSynthesis?.cancel();S.mode="idle";S.msgs=[];S.product=null;S.pointDir=null;render()},120000)}
function toast(msg){S.toast=msg;render();setTimeout(()=>{S.toast=null;render()},3500)}
function scroll(){setTimeout(()=>{document.getElementById('ce')?.scrollIntoView({behavior:'smooth'})},60)}

// ═══ API ═══
async function callAPI(msgs){
  if(!S.apiKey){S.showSettings=true;render();throw new Error('API key gerekli')}
  const res=await fetch("https://api.anthropic.com/v1/messages",{
    method:"POST",
    headers:{
      "Content-Type":"application/json",
      "x-api-key":S.apiKey,
      "anthropic-version":"2023-06-01",
      "anthropic-dangerous-direct-browser-access":"true"
    },
    body:JSON.stringify({model:"claude-sonnet-4-20250514",max_tokens:500,system:SYS,
      messages:msgs.map(m=>({role:m.role,content:m.content}))})
  });
  if(!res.ok){
    const err=await res.json().catch(()=>({}));
    if(res.status===401){toast("API key gecersiz. Ayarlardan kontrol edin.");S.showSettings=true;render();throw new Error('Invalid key')}
    throw new Error(err.error?.message||'API hatasi');
  }
  const data=await res.json();
  const raw=data.content?.map(c=>c.text||"").join("")||'';
  try{const m=raw.match(/\{[\s\S]*?\}/);if(m){const p=JSON.parse(m[0]);return{msg:p.message||"",pid:p.product_id||null}}}catch(e){}
  return{msg:raw.replace(/[{}"]/g,"").replace(/message:|product_id:\s*null/gi,"").trim()||"Bir sorun olustu.",pid:null};
}

// ═══ ACTIONS ═══
async function handleStart(){
  if(!S.apiKey){S.showSettings=true;render();toast("Lutfen once API key giriniz");return}
  const g="Hos geldiniz! Ben Elfin, dijital magaza asistaniyim. Size nasil yardimci olabilirim?";
  S.mode="greeting";S.msgs=[{role:"assistant",content:g}];S.product=null;S.pointDir=null;render();
  await speak(g);
  S.mode="listening";render();resetInact();
}

async function sendMsg(text){
  const msg=(text||S.input).trim();if(!msg||S.loading)return;
  S.input="";S.product=null;S.pointDir=null;resetInact();
  S.msgs.push({role:"user",content:msg});S.loading=true;S.mode="thinking";render();scroll();
  try{
    const{msg:reply,pid}=await callAPI(S.msgs);
    S.msgs.push({role:"assistant",content:reply});
    if(pid){const p=PRODUCTS.find(x=>x.id===pid);if(p){const side=S.lastSide==="right"?"left":"right";S.lastSide=side;S.pSide=side;S.pointDir=side;S.product=p;}}
    S.loading=false;render();scroll();
    await speak(reply);
    if(!pid)S.pointDir=null;
    S.mode="listening";render();
  }catch(e){
    if(!S.msgs[S.msgs.length-1]||S.msgs[S.msgs.length-1].role!=="assistant")
      S.msgs.push({role:"assistant",content:"Baglanti hatasi, lutfen tekrar deneyin."});
    S.loading=false;S.mode="listening";render();scroll();
  }
}

function handleReset(){speechSynthesis?.cancel();stopMouth();S.mode="idle";S.msgs=[];S.input="";S.product=null;S.pointDir=null;S.loading=false;render()}

// ═══ AVATAR SVG ═══
function avSVG(sc){
  const md=S.mode,bl=S.blink,ex=S.eye.x,ey=S.eye.y,mp=S.mouth,pd=S.pointDir;
  const isA=md!=="idle";
  const ht=md==="thinking"?4:md==="greeting"?-3:pd==="right"?-4:pd==="left"?4:0;
  const br=md==="greeting"?-3:md==="thinking"?-2:0;
  const la=pd==="left"?"M72 260Q30 230 15 190Q8 170 18 165":"M72 260Q58 285 55 315Q53 330 58 335";
  const ra=pd==="right"?"M228 260Q270 230 285 190Q292 170 282 165":"M228 260Q242 285 245 315Q247 330 242 335";
  const lx=pd==="left"?14:55,ly=pd==="left"?162:333,rx=pd==="right"?286:245,ry=pd==="right"?162:333;
  const lf=pd==="left"?'<g transform="translate(-2,-10)rotate(-30,14,165)"><line x1="10"y1="158"x2="2"y2="145"stroke="#f5d0a9"stroke-width="3.5"stroke-linecap="round"/><line x1="14"y1="155"x2="8"y2="140"stroke="#f5d0a9"stroke-width="3.2"stroke-linecap="round"/><line x1="18"y1="155"x2="14"y2="140"stroke="#f5d0a9"stroke-width="3"stroke-linecap="round"/></g>':'';
  const rf=pd==="right"?'<g transform="translate(2,-10)rotate(30,286,165)"><line x1="290"y1="158"x2="298"y2="145"stroke="#f5d0a9"stroke-width="3.5"stroke-linecap="round"/><line x1="286"y1="155"x2="292"y2="140"stroke="#f5d0a9"stroke-width="3.2"stroke-linecap="round"/><line x1="282"y1="155"x2="286"y2="140"stroke="#f5d0a9"stroke-width="3"stroke-linecap="round"/></g>':'';
  const mo=md==="speaking"?`<ellipse cx="150"cy="185"rx="${mp===2?14:mp===1?10:7}"ry="${mp===0?3:mp===1?8:12}"fill="#b8423a"stroke="#c4524a"stroke-width="1.5"style="transition:all .08s"/>`
    :`<path d="${isA?"M134 181Q142 192 150 192Q158 192 166 181":"M136 183Q143 188 150 188Q157 188 164 183"}"stroke="#c4524a"stroke-width="2.5"fill="none"stroke-linecap="round"style="transition:all .5s"/>`;
  const bsh=isA?'<ellipse cx="105"cy="168"rx="12"ry="7"fill="#ffb4a8"opacity=".18"/><ellipse cx="195"cy="168"rx="12"ry="7"fill="#ffb4a8"opacity=".18"/>':'';
  const lg=md==="listening"?'<circle cx="86"cy="142"r="3"fill="#ffc72c"><animate attributeName="opacity"values=".2;.8;.2"dur="1.5s"repeatCount="indefinite"/></circle>':'';
  const thk=md==="thinking"?[0,1,2].map(i=>`<circle cx="${138+i*12}"cy="360"r="4.5"fill="#00c8ff"><animate attributeName="opacity"values=".2;1;.2"dur="1.2s"repeatCount="indefinite"begin="${i*.2}s"/></circle>`).join(''):'';
  const idp=md==="idle"?'<circle cx="150"cy="155"r="90"fill="none"stroke="#00c8ff"stroke-width=".6"opacity="0"><animate attributeName="r"values="90;130"dur="3.5s"repeatCount="indefinite"/><animate attributeName="opacity"values=".3;0"dur="3.5s"repeatCount="indefinite"/></circle>':'';
  const w=Math.round(240*(sc||1));
  return`<svg viewBox="0 0 300 380"width="${w}"style="filter:drop-shadow(0 12px 40px rgba(0,200,255,.15))">
