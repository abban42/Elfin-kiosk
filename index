function rAvatar(){const el=document.getElementById('avc');if(el)el.innerHTML=avSVG(S.mode!=="idle"?.55:.85)}

// ═══ PRODUCT CARD ═══
function pcHTML(p,side){
  if(!p)return'';
  const tc={tarife:"#ffc72c",cihaz:"#00c8ff",internet:"#22c55e"},tl={tarife:"TARIFE",cihaz:"CIHAZ",internet:"INTERNET"};
  const c=tc[p.type];
  return`<div class="pc-w ${side}"><div class="pc"style="border:1px solid ${c}44;box-shadow:0 8px 24px ${c}22">
<div class="pc-h"><span class="pc-t"style="color:${c}">${tl[p.type]}</span><button class="pc-x"onclick="clProd()">✕</button></div>
<div class="pc-n">${p.name}</div><div class="pc-p"style="color:${c}">${p.price}</div>
<div class="pc-d">${p.desc}</div>
<div class="pc-fs">${p.features.map(f=>`<span class="pc-f"style="background:${c}15;color:${c};border:1px solid ${c}30">${f}</span>`).join('')}</div>
<button class="pc-btn"style="background:linear-gradient(135deg,${c},${c}cc);color:${p.type==="tarife"?"#060a14":"#fff"}"onclick="shDet('${p.id}')">Detayli Bilgi</button>
<div class="pc-hint">Sohbete devam edebilirsiniz</div></div></div>`}

// ═══ RENDER ═══
function render(){
  const ic=S.mode!=="idle";
  const stL={idle:"Bekleniyor",greeting:"Karsilama",listening:"Dinliyor",thinking:"Dusunuyor...",speaking:"Konusuyor"};
  const stC=S.mode==="idle"?"var(--txD)":"var(--gn)";
  let h='';

  // Header
  h+=`<div class="header"><div class="hdr-l"><div class="logo">E</div><div><div style="font-size:14px;font-weight:700">Elfin Iletisim</div><div style="font-size:10px;color:var(--txD)">AI Asistan v3</div></div></div>
<div class="hdr-r"><div class="st-badge"><div class="st-dot"style="background:${stC};box-shadow:${S.mode!=="idle"?`0 0 8px var(--gn)`:"none"}"></div>${stL[S.mode]}</div>
<button class="btn-s"onclick="S.showSettings=true;render()">⚙</button>
${ic?'<button class="btn-s"onclick="handleReset()">Sifirla</button>':''}</div></div>`;

  h+=`<div class="stage">`;
  // Avatar
  h+=`<div class="av-area ${ic?"active":"idle"}">`;
  if(S.product&&S.pSide==="left")h+=pcHTML(S.product,"left");
  h+=`<div id="avc"style="z-index:6;position:relative">${avSVG(ic?.55:.85)}</div>`;
  if(S.product&&S.pSide==="right")h+=pcHTML(S.product,"right");
  h+=`</div>`;

  if(!ic){
    const hasKey=!!S.apiKey;
    h+=`<div class="idle-s"><div class="idle-t">Merhaba, ben <b>Elfin</b></div><div class="idle-sub">Size nasil yardimci olabilirim?</div>
${!hasKey?`<button class="btn-s"style="padding:10px 24px;font-size:13px;margin-bottom:12px"onclick="S.showSettings=true;render()">Once API Key Ayarlayin</button><br>`:''}
<button class="btn-go"onclick="handleStart()"${!hasKey?'style="opacity:.5"':''}>Musteri Algilandi — Baslat</button>
<div style="font-size:10px;color:var(--txD);margin-top:8px;opacity:.5">Kamera ile otomatik algilama eklenecek</div></div>`;
  }

  if(ic){
    h+=`<div class="chat"id="ca"><div class="chat-sp"></div>`;
    S.msgs.forEach(m=>{h+=`<div class="bw ${m.role==='user'?'u':'a'}"><div class="bb ${m.role==='user'?'u':'a'}">${m.content}</div></div>`});
    if(S.loading)h+=`<div class="td"><span></span><span></span><span></span></div>`;
    if(S.msgs.length===1&&!S.loading)h+=`<div class="chips">
<button class="chip"onclick="sendMsg('Bana uygun tarife onerir misin?')">Tarifeler</button>
<button class="chip"onclick="sendMsg('Telefon almak istiyorum')">Telefonlar</button>
<button class="chip"onclick="sendMsg('Ev interneti paketleri?')">Ev Interneti</button>
<button class="chip"onclick="sendMsg('Numara tasimak istiyorum')">Numara Tasima</button></div>`;
    h+=`<div id="ce"></div></div>`;
  }
  h+=`</div>`;

  if(ic){
    const dis=S.loading||S.mode==="speaking";
    const hasI=S.input.trim().length>0;
    h+=`<div class="inbar">
<div class="ptt-w"><button class="ptt"id="ptt"style="background:${S.holding?"var(--rd)":dis?"var(--cd)":"linear-gradient(135deg,var(--gn),#18a34a)"};transform:${S.holding?"scale(1.12)":"scale(1)"};box-shadow:${S.holding?"0 0 20px rgba(239,68,68,.5)":"none"};opacity:${dis?.4:1}">${S.holding?"🔴":"🎤"}</button><span class="ptt-l">${S.holding?"Konusun...":"Basili tut"}</span></div>
<input id="mi"value="${escH(S.input)}"placeholder="veya yazarak sorun..."${dis?"disabled":""}/>
<button class="snd"onclick="sendMsg()"style="background:${hasI?"var(--pr)":"var(--cd)"};color:${hasI?"var(--bg)":"var(--txD)"}">➤</button></div>`;
  }

  document.getElementById('app').innerHTML=h;

  // Bind events
  const mi=document.getElementById('mi');
  if(mi){mi.addEventListener('input',e=>S.input=e.target.value);mi.addEventListener('keydown',e=>{if(e.key==='Enter')sendMsg()})}
  const ptt=document.getElementById('ptt');
  if(ptt&&!ptt._b){ptt._b=true;ptt.addEventListener('mousedown',startSTT);ptt.addEventListener('mouseup',stopSTT);ptt.addEventListener('mouseleave',stopSTT);
    ptt.addEventListener('touchstart',e=>{e.preventDefault();startSTT()});ptt.addEventListener('touchend',e=>{e.preventDefault();stopSTT()})}

  // Settings
  if(S.showSettings)renderSettings();
  // Toast
  const tr=document.getElementById('toast-root');
  tr.innerHTML=S.toast?`<div class="toast">${S.toast}</div>`:'';
  scroll();
}

function renderSettings(){
  const isHttps=location.protocol==='https:';
  const hasTTS='speechSynthesis' in window;
  const hasSTT=!!SR;
  let h=`<div class="settings-overlay"onclick="S.showSettings=false;render()">
<div class="settings-card"onclick="event.stopPropagation()">
<div class="settings-title">Ayarlar<button style="background:none;border:none;color:var(--txD);font-size:18px;cursor:pointer"onclick="S.showSettings=false;render()">✕</button></div>

<label class="settings-label">Claude API Key</label>
<input class="settings-input"id="api-inp"type="password"value="${escH(S.apiKey)}"placeholder="sk-ant-..."/>

<button class="settings-btn"onclick="saveKey()">Kaydet</button>

<div style="margin-top:14px">
<div class="settings-status"><span class="${S.apiKey?'settings-ok':'settings-no'}">${S.apiKey?'✓':'✗'}</span> API Key ${S.apiKey?'ayarli':'gerekli'}</div>
<div class="settings-status"><span class="${hasTTS?'settings-ok':'settings-no'}">${hasTTS?'✓':'✗'}</span> Ses Sentezi (TTS) ${hasTTS?'mevcut':'yok'}</div>
<div class="settings-status"><span class="${hasSTT&&isHttps?'settings-ok':'settings-no'}">${hasSTT&&isHttps?'✓':'✗'}</span> Ses Tanima (STT) ${!hasSTT?'desteklenmiyor':!isHttps?'HTTPS gerekli':'hazir'}</div>
<div class="settings-status"><span class="${isHttps?'settings-ok':'settings-no'}">${isHttps?'✓':'✗'}</span> HTTPS ${isHttps?'aktif':'degil (mikrofon icin gerekli)'}</div>
</div>

<div class="settings-note">
<b>API Key nereden alinir?</b><br>
console.anthropic.com → API Keys → Create Key<br><br>
<b>Mikrofon icin:</b><br>
Bu dosyayi GitHub Pages veya Vercel'e deploy edin. Yerel dosyada mikrofon calismaz.<br><br>
<b>API key guvenle saklanir</b> — sadece bu cihazin tarayicisinda kalir.
</div>
</div></div>`;
  
  let el=document.getElementById('settings-root');
  if(!el){el=document.createElement('div');el.id='settings-root';document.body.appendChild(el)}
  el.innerHTML=h;
}

function saveKey(){
  const v=document.getElementById('api-inp')?.value?.trim()||'';
  S.apiKey=v;
  localStorage.setItem('elfin_api_key',v);
  S.showSettings=false;
  toast(v?"API key kaydedildi!":"API key silindi");
  render();
}

function escH(s){return(s||'').replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;')}

// Detail modal
window.shDet=function(id){
  S.detailProd=PRODUCTS.find(p=>p.id===id);
  if(!S.detailProd)return;
  const p=S.detailProd,tc={tarife:"#ffc72c",cihaz:"#00c8ff",internet:"#22c55e"},c=tc[p.type];
  document.getElementById('modal-root').innerHTML=`<div class="mo"onclick="clDet()">
<div class="mc"style="border:1px solid ${c}55;box-shadow:0 20px 60px ${c}33"onclick="event.stopPropagation()">
<div style="display:flex;justify-content:space-between;margin-bottom:14px"><div style="font-size:11px;color:${c};font-weight:600;text-transform:uppercase;letter-spacing:.1em">${p.type.toUpperCase()} DETAYI</div><button class="mc-x"onclick="clDet()">✕</button></div>
<div style="font-size:22px;font-weight:800;margin-bottom:4px">${p.name}</div>
<div style="font-size:26px;font-weight:800;color:${c};margin-bottom:14px">${p.price}</div>
<div style="font-size:13px;color:var(--txM);line-height:1.6;margin-bottom:16px">${p.desc}</div>
<div style="font-size:12px;font-weight:600;margin-bottom:8px">Ozellikler</div>
<div class="mf">${p.features.map(f=>`<div class="mfi"><div class="mfi-d"style="background:${c}"></div>${f}</div>`).join('')}</div>
<button class="mc-btn"style="background:linear-gradient(135deg,${c},${c}bb);color:${p.type==="tarife"?"var(--bg)":"#fff"}"onclick="clDet()">Personel Cagir</button>
</div></div>`};
window.clDet=function(){S.detailProd=null;document.getElementById('modal-root').innerHTML=''};
window.clProd=function(){S.product=null;S.pointDir=null;render()};
window.handleStart=handleStart;window.handleReset=handleReset;window.sendMsg=sendMsg;window.S=S;

// INIT
render();
// Show settings if no API key
if(!S.apiKey){setTimeout(()=>{S.showSettings=true;render()},500)}
</script>
</body>
</html>
